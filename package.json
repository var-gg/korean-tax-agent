{
  "name": "korean-tax-agent",
  "private": false,
  "version": "0.1.0",
  "description": "Open-source, agent-native workflow for Korean comprehensive income tax filing.",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "demo": "tsx scripts/run-demo.ts",
    "smoke:workflow": "tsx scripts/smoke-workflow.ts",
    "smoke:openclaw-runtime": "tsx scripts/smoke-openclaw-runtime.ts",
    "smoke:openclaw-bridge": "tsx scripts/smoke-openclaw-bridge.ts",
    "smoke:openclaw-reconnect-snapshot": "tsx scripts/smoke-openclaw-reconnect-snapshot.ts",
    "smoke:openclaw-action": "tsx scripts/smoke-openclaw-action.ts",
    "example:browser-assist": "tsx examples/browser-assist-hometax.ts",
    "example:openclaw-browser-assist": "tsx examples/browser-assist-openclaw-adapter.ts",
    "example:openclaw-live-bridge": "tsx examples/browser-assist-openclaw-live-bridge.ts"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.19.2",
    "typescript": "^5.8.2",
    "vitest": "^4.0.18"
  }
}
